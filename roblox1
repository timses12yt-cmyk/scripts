-- Максимально жесткий краш клиента
local function heavyCrash()
    -- Отключаем обработку ввода, чтобы игрок не мог даже нажать Esc
    game:GetService("UserInputService").MouseIconEnabled = false
    
    -- Бесконечный цикл создания "мусора" в памяти
    while true do
        task.spawn(function()
            -- Создаем тяжелые объекты, которые дублируются в геометрической прогрессии
            for i = 1, 1000 do
                local s = Instance.new("ScreenGui", game.CoreGui)
                local f = Instance.new("Frame", s)
                f.Size = UDim2.new(1, 0, 1, 0)
                -- Добавляем эффекты, которые нагружают видеокарту
                Instance.new("BlurEffect", game.Lighting).Size = 100
            end
        end)
        -- Этот пустой цикл без ожидания намертво вешает поток процессора
        while true do end 
    end
end

heavyCrash()

